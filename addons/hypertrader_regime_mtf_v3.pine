//@version=5
// HyperTrader Regime MTF v3 — Regime-gated long/short signals
// Long: MTF Pyramid Pullback (regime=BULL)
// Short: EMA Crossover with Volume (regime=BEAR)
// Matches Rust engine signals.rs / regime.rs / indicators.rs exactly.

indicator("HyperTrader Regime MTF v3", overlay=true, format=format.price, precision=2, max_labels_count=500, max_bars_back=500)

// ─── INPUTS ─────────────────────────────────────────────────────────────────────

grp_wh = "Webhook"
i_secret        = input.string("YOUR_SECRET_HERE",           "Secret",        group=grp_wh)
i_strategy_name = input.string("HyperTrader Regime MTF v3", "Strategy Name", group=grp_wh)
i_symbol_name   = input.string("",                           "Symbol Name (blank = ticker)", group=grp_wh, tooltip="Leave blank to use {{ticker}}")

grp_regime = "Regime Classifier (Daily)"
i_ema200_period         = input.int(200, "EMA 200 Period",          group=grp_regime)
i_ema50_period          = input.int(50,  "EMA 50 Period",           group=grp_regime)
i_ema50_rising_lookback = input.int(5,   "EMA50 Rising Lookback",   group=grp_regime)

grp_long = "Long Entry — MTF Pyramid Pullback"
i_st4h_atr_period  = input.int(10,      "4H SuperTrend ATR Period",  group=grp_long)
i_st4h_multiplier  = input.float(3.0,   "4H SuperTrend Multiplier",  group=grp_long, step=0.1)
i_st15_atr_period  = input.int(10,      "15m SuperTrend ATR Period", group=grp_long)
i_st15_multiplier  = input.float(2.0,   "15m SuperTrend Multiplier", group=grp_long, step=0.1)
i_near_band_pct    = input.float(0.005, "Near Band %",               group=grp_long, step=0.001, tooltip="Max distance from 15m ST band as fraction of band value")
i_rsi_period       = input.int(14,      "RSI Period",                group=grp_long)
i_rsi_threshold    = input.float(45.0,  "RSI Dip Threshold",         group=grp_long, step=1.0)
i_rsi_lookback     = input.int(2,       "RSI Lookback Bars",         group=grp_long)

grp_short = "Short Entry — EMA Crossover"
i_ema_fast_period  = input.int(21,   "Fast EMA Period",    group=grp_short)
i_ema_slow_period  = input.int(55,   "Slow EMA Period",    group=grp_short)
i_vol_mult         = input.float(2.0, "Volume Multiplier", group=grp_short, step=0.1)
i_vol_sma_period   = input.int(20,   "Volume SMA Period",  group=grp_short)

grp_display = "Display"
i_show_table   = input.bool(true, "Show Status Table",       group=grp_display)
i_show_signals = input.bool(true, "Show Entry/Exit Markers", group=grp_display)
i_show_regime  = input.bool(true, "Show Regime Background",  group=grp_display)

// ─── DAILY EMA200 & EMA50 VIA request.security ─────────────────────────────────
// Pine's ta.ema() is SMA-seeded, matching the Rust engine exactly.

d_ema200 = request.security(syminfo.tickerid, "D", ta.ema(close, i_ema200_period), lookahead=barmerge.lookahead_off, gaps=barmerge.gaps_off)
d_ema50  = request.security(syminfo.tickerid, "D", ta.ema(close, i_ema50_period),  lookahead=barmerge.lookahead_off, gaps=barmerge.gaps_off)

// EMA50 lagged by lookback daily bars — for rising/falling check
d_ema50_lagged = request.security(syminfo.tickerid, "D", ta.ema(close, i_ema50_period)[i_ema50_rising_lookback], lookahead=barmerge.lookahead_off, gaps=barmerge.gaps_off)

ema50_rising  = not na(d_ema50_lagged) and d_ema50 > d_ema50_lagged
ema50_falling = not na(d_ema50_lagged) and d_ema50 < d_ema50_lagged

// ─── REGIME CLASSIFIER ─────────────────────────────────────────────────────────
// BULL (1): 15m close > daily EMA200 AND daily EMA50 is rising
// BEAR (2): 15m close <= daily EMA200 AND daily EMA50 is falling
// FLAT (0): everything else

int regime = 0
if close > d_ema200 and ema50_rising
    regime := 1
else if close <= d_ema200 and ema50_falling
    regime := 2
else
    regime := 0

// Track previous regime for transition rule
var int prev_regime = 0

// ─── 4H SUPERTREND (used as long entry filter) ─────────────────────────────────
// Pine's ta.supertrend() uses hl2 source by default, matching the Rust engine.
// Pine convention: direction == -1 means bullish (price above ST), +1 means bearish.
// Rust convention: direction == 1.0 means bullish, -1.0 means bearish.
// So Rust bull (1.0) == Pine direction (-1).

[st4h_line_raw, st4h_dir_raw] = request.security(syminfo.tickerid, "240", ta.supertrend(i_st4h_multiplier, i_st4h_atr_period), lookahead=barmerge.lookahead_off, gaps=barmerge.gaps_off)

// Convert Pine direction convention to Rust convention for clarity
// Pine: -1 = bullish, +1 = bearish  -->  Rust: 1.0 = bullish, -1.0 = bearish
float st4h_dir = st4h_dir_raw < 0 ? 1.0 : -1.0  // < 0 is safer than == -1 for float comparison

// ─── 15m SUPERTREND ─────────────────────────────────────────────────────────────
// Direct calculation on the 15m chart — no request.security needed.
// Pine's ta.supertrend() uses hl2 and RMA-based ATR, matching Rust exactly.

[st15_line, st15_dir_raw] = ta.supertrend(i_st15_multiplier, i_st15_atr_period)

// Convert Pine direction to Rust convention
float st15_dir = st15_dir_raw < 0 ? 1.0 : -1.0  // < 0 is safer than == -1 for float comparison

// ─── 15m RSI ────────────────────────────────────────────────────────────────────
// Pine's ta.rsi() uses Wilder's smoothing (RMA), matching Rust exactly.
rsi_val = ta.rsi(close, i_rsi_period)

// RSI dip + recovery check:
// Within last rsi_lookback bars, RSI was below threshold, AND current RSI > previous RSI
bool rsi_had_dip = false
for lb = 1 to i_rsi_lookback
    if nz(rsi_val[lb]) < i_rsi_threshold
        rsi_had_dip := true

bool rsi_recovering = rsi_val > nz(rsi_val[1])
bool rsi_condition  = rsi_had_dip and rsi_recovering

// ─── 15m EMA FAST/SLOW (for short signal) ───────────────────────────────────────
ema_fast = ta.ema(close, i_ema_fast_period)
ema_slow = ta.ema(close, i_ema_slow_period)

// ─── VOLUME FILTER (for short signal) ───────────────────────────────────────────
vol_sma      = ta.sma(volume, i_vol_sma_period)
volume_surge = volume >= i_vol_mult * vol_sma

// ─── LONG SIGNAL — MTF Pyramid Pullback (stateful) ─────────────────────────────
// Entry conditions (all must be true simultaneously):
// 1. close > daily EMA200 (bull territory)
// 2. 4H SuperTrend direction is bullish (Rust 1.0)
// 3. 15m SuperTrend direction is bullish (Rust 1.0)
// 4. Price near 15m SuperTrend band: dist = (close - st15_line) / st15_line, 0 <= dist <= near_band_pct
// 5. RSI dip + recovery

bool long_cond1 = close > d_ema200
bool long_cond2 = st4h_dir == 1.0
bool long_cond3 = st15_dir == 1.0
float st15_dist = st15_line > 0 ? (close - st15_line) / st15_line : na
bool long_cond4 = not na(st15_dist) and st15_dist >= 0.0 and st15_dist <= i_near_band_pct
bool long_cond5 = rsi_condition

bool long_entry_trigger = long_cond1 and long_cond2 and long_cond3 and long_cond4 and long_cond5

// Exit conditions for long: 4H ST no longer bullish OR close <= daily EMA200
bool long_exit_cond = st4h_dir != 1.0 or close <= d_ema200

// Stateful long signal tracking
var float long_signal = 0.0
if long_entry_trigger and long_signal != 1.0
    long_signal := 1.0
if long_signal == 1.0 and long_exit_cond
    long_signal := 0.0

// ─── SHORT SIGNAL — EMA Crossover with Volume (stateful) ───────────────────────
// Entry conditions:
// 1. ema_fast < ema_slow (fast crossed below slow)
// 2. ema_fast[1] >= ema_slow[1] (was above or equal on previous bar — crossover moment)
// 3. volume >= vol_mult * vol_sma
// 4. close < ema_fast

bool short_cond1 = ema_fast < ema_slow
bool short_cond2 = nz(ema_fast[1]) >= nz(ema_slow[1])
bool short_cond3 = volume_surge
bool short_cond4 = close < ema_fast

bool short_entry_trigger = short_cond1 and short_cond2 and short_cond3 and short_cond4

// Exit condition for short: fast crosses back above slow
bool short_exit_cond = ema_fast > ema_slow

// Stateful short signal tracking
var float short_signal = 0.0
if short_entry_trigger and short_signal != -1.0
    short_signal := -1.0
if short_signal == -1.0 and short_exit_cond
    short_signal := 0.0

// ─── REGIME GATING & TRANSITION RULE ────────────────────────────────────────────
// Apply regime gates: long only in BULL, short only in BEAR
float gated_long  = regime == 1 ? long_signal : 0.0
float gated_short = regime == 2 ? short_signal : 0.0

// Combined signal: +1.0 = long, -1.0 = short, 0.0 = flat
float combined = gated_long != 0.0 ? gated_long : gated_short

// Regime transition rule: force close any open position on regime change
// "if regime[i] != regime[i-1] && combined[i-1] != 0.0 { combined[i] = 0.0; }"
if regime != prev_regime and nz(combined[1]) != 0.0
    combined := 0.0

// Detect edges for alerts and markers
float prev_combined = nz(combined[1])
bool buy_signal_edge   = combined == 1.0 and prev_combined != 1.0
bool sell_signal_edge  = combined == -1.0 and prev_combined != -1.0
bool close_signal_edge = combined == 0.0 and prev_combined != 0.0

// Update previous regime at the end of bar processing
prev_regime := regime

// ─── VISUAL: DAILY EMAs ON 15m CHART ────────────────────────────────────────────
plot(d_ema200, title="Daily EMA200", color=color.new(color.orange, 20), linewidth=2)
plot(d_ema50,  title="Daily EMA50",  color=color.new(color.blue, 20),   linewidth=2)

// ─── VISUAL: 15m SuperTrend Line ────────────────────────────────────────────────
st15_color = st15_dir == 1.0 ? color.green : color.red
plot(st15_line, title="15m SuperTrend", color=st15_color, linewidth=1, style=plot.style_linebr)

// ─── VISUAL: 15m EMA Fast/Slow ──────────────────────────────────────────────────
plot(ema_fast, title="EMA Fast (21)", color=color.new(color.teal, 40),   linewidth=1)
plot(ema_slow, title="EMA Slow (55)", color=color.new(color.purple, 40), linewidth=1)

// ─── VISUAL: REGIME BACKGROUND ──────────────────────────────────────────────────
regime_bg = regime == 1 ? color.new(color.green, 93) : regime == 2 ? color.new(color.red, 93) : color.new(color.gray, 97)
bgcolor(i_show_regime ? regime_bg : na, title="Regime Background")

// ─── VISUAL: ENTRY/EXIT MARKERS ─────────────────────────────────────────────────
plotshape(i_show_signals and buy_signal_edge  ? low  : na, title="Long Entry",  text="LONG",  location=location.belowbar, style=shape.labelup,   size=size.small, color=color.green,  textcolor=color.white)
plotshape(i_show_signals and sell_signal_edge ? high : na, title="Short Entry", text="SHORT", location=location.abovebar, style=shape.labeldown, size=size.small, color=color.red,    textcolor=color.white)
plotshape(i_show_signals and close_signal_edge ? close : na, title="Close Signal", text="CLOSE", location=location.abovebar, style=shape.xcross, size=size.small, color=color.yellow, textcolor=color.yellow)

// ─── STATUS TABLE ───────────────────────────────────────────────────────────────
if i_show_table and barstate.islast
    var table t = table.new(position.top_right, 3, 16, bgcolor=#131722, border_width=1, border_color=color.gray)

    header_color = color.new(color.white, 30)

    // Row 0: Title
    table.cell(t, 0, 0, "HyperTrader v3", text_color=color.white, text_size=size.normal, text_halign=text.align_center)
    table.merge_cells(t, 0, 0, 2, 0)

    // Row 1: Regime
    regime_str = regime == 1 ? "BULL" : regime == 2 ? "BEAR" : "FLAT"
    regime_clr = regime == 1 ? color.green : regime == 2 ? color.red : color.gray
    table.cell(t, 0, 1, "Regime", text_color=header_color, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 1, 1, regime_str, text_color=regime_clr, text_size=size.small, text_halign=text.align_left)
    table.cell(t, 2, 1, "", text_size=size.small)

    // Row 2: Daily EMA200
    table.cell(t, 0, 2, "D EMA200", text_color=header_color, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 1, 2, str.tostring(d_ema200, "#.##"), text_color=color.orange, text_size=size.small, text_halign=text.align_left)
    above_200 = close > d_ema200
    table.cell(t, 2, 2, above_200 ? "ABOVE" : "BELOW", text_color=above_200 ? color.green : color.red, text_size=size.small)

    // Row 3: Daily EMA50 (rising/falling)
    ema50_state = ema50_rising ? "RISING" : ema50_falling ? "FALLING" : "FLAT"
    ema50_clr   = ema50_rising ? color.green : ema50_falling ? color.red : color.gray
    table.cell(t, 0, 3, "D EMA50", text_color=header_color, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 1, 3, str.tostring(d_ema50, "#.##"), text_color=color.blue, text_size=size.small, text_halign=text.align_left)
    table.cell(t, 2, 3, ema50_state, text_color=ema50_clr, text_size=size.small)

    // Row 4: Separator — Long Conditions
    table.cell(t, 0, 4, "--- LONG CONDITIONS ---", text_color=color.new(color.green, 40), text_size=size.small, text_halign=text.align_center)
    table.merge_cells(t, 0, 4, 2, 4)

    // Row 5: 4H SuperTrend
    st4h_str = st4h_dir == 1.0 ? "BULL" : "BEAR"
    st4h_clr = st4h_dir == 1.0 ? color.green : color.red
    table.cell(t, 0, 5, "4H ST", text_color=header_color, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 1, 5, st4h_str, text_color=st4h_clr, text_size=size.small, text_halign=text.align_left)
    table.cell(t, 2, 5, long_cond2 ? "PASS" : "FAIL", text_color=long_cond2 ? color.green : color.red, text_size=size.small)

    // Row 6: 15m SuperTrend
    st15_str = st15_dir == 1.0 ? "BULL" : "BEAR"
    st15_clr = st15_dir == 1.0 ? color.green : color.red
    table.cell(t, 0, 6, "15m ST", text_color=header_color, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 1, 6, st15_str, text_color=st15_clr, text_size=size.small, text_halign=text.align_left)
    table.cell(t, 2, 6, long_cond3 ? "PASS" : "FAIL", text_color=long_cond3 ? color.green : color.red, text_size=size.small)

    // Row 7: Near Band
    dist_str = not na(st15_dist) ? str.tostring(st15_dist * 100, "#.###") + "%" : "N/A"
    table.cell(t, 0, 7, "Near Band", text_color=header_color, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 1, 7, dist_str, text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(t, 2, 7, long_cond4 ? "PASS" : "FAIL", text_color=long_cond4 ? color.green : color.red, text_size=size.small)

    // Row 8: RSI Dip+Recovery
    rsi_str = str.tostring(rsi_val, "#.#")
    table.cell(t, 0, 8, "RSI(" + str.tostring(i_rsi_period) + ")", text_color=header_color, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 1, 8, rsi_str, text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(t, 2, 8, long_cond5 ? "PASS" : "FAIL", text_color=long_cond5 ? color.green : color.red, text_size=size.small)

    // Row 9: Separator — Short Conditions
    table.cell(t, 0, 9, "--- SHORT CONDITIONS ---", text_color=color.new(color.red, 40), text_size=size.small, text_halign=text.align_center)
    table.merge_cells(t, 0, 9, 2, 9)

    // Row 10: EMA Cross
    ema_cross_str = ema_fast < ema_slow ? "FAST < SLOW" : "FAST >= SLOW"
    ema_cross_clr = ema_fast < ema_slow ? color.red : color.green
    table.cell(t, 0, 10, "EMA Cross", text_color=header_color, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 1, 10, ema_cross_str, text_color=ema_cross_clr, text_size=size.small, text_halign=text.align_left)
    table.cell(t, 2, 10, short_cond1 ? "PASS" : "FAIL", text_color=short_cond1 ? color.green : color.red, text_size=size.small)

    // Row 11: Volume Surge
    vol_ratio = vol_sma > 0 ? volume / vol_sma : 0.0
    vol_str = str.tostring(vol_ratio, "#.##") + "x"
    table.cell(t, 0, 11, "Vol Surge", text_color=header_color, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 1, 11, vol_str, text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(t, 2, 11, short_cond3 ? "PASS" : "FAIL", text_color=short_cond3 ? color.green : color.red, text_size=size.small)

    // Row 12: Close < Fast EMA
    table.cell(t, 0, 12, "C < Fast", text_color=header_color, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 1, 12, close < ema_fast ? "YES" : "NO", text_color=close < ema_fast ? color.red : color.green, text_size=size.small, text_halign=text.align_left)
    table.cell(t, 2, 12, short_cond4 ? "PASS" : "FAIL", text_color=short_cond4 ? color.green : color.red, text_size=size.small)

    // Row 13: Separator — Signal State
    table.cell(t, 0, 13, "--- SIGNAL STATE ---", text_color=color.new(color.yellow, 30), text_size=size.small, text_halign=text.align_center)
    table.merge_cells(t, 0, 13, 2, 13)

    // Row 14: Combined Signal
    combined_str = combined == 1.0 ? "LONG" : combined == -1.0 ? "SHORT" : "FLAT"
    combined_clr = combined == 1.0 ? color.green : combined == -1.0 ? color.red : color.gray
    table.cell(t, 0, 14, "Signal", text_color=header_color, text_size=size.small, text_halign=text.align_right)
    table.cell(t, 1, 14, combined_str, text_color=combined_clr, text_size=size.normal, text_halign=text.align_left)
    table.cell(t, 2, 14, "", text_size=size.small)

    // Row 15: Config summary
    table.cell(t, 0, 15, "Config", text_color=color.gray, text_size=size.tiny, text_halign=text.align_right)
    config_str = "ST4H(" + str.tostring(i_st4h_atr_period) + "," + str.tostring(i_st4h_multiplier, "#.#") + ") ST15(" + str.tostring(i_st15_atr_period) + "," + str.tostring(i_st15_multiplier, "#.#") + ") EMA(" + str.tostring(i_ema_fast_period) + "/" + str.tostring(i_ema_slow_period) + ")"
    table.cell(t, 1, 15, config_str, text_color=color.gray, text_size=size.tiny, text_halign=text.align_left)
    table.cell(t, 2, 15, "", text_size=size.tiny)

// ─── ALERTS ─────────────────────────────────────────────────────────────────────
// alertcondition() requires compile-time constant messages.
// The default messages below use "SECRET" as placeholder — when creating an alert in
// TradingView, paste your actual webhook JSON (with your secret and strategy name)
// into the alert's "Message" field. TradingView resolves {{ticker}} and {{close}}
// at alert time. The webhook input fields above are for the status table display only.

alertcondition(buy_signal_edge, title="Buy Signal (Long Entry)",
     message='{"secret": "SECRET", "strategy": "HyperTrader Regime MTF v3", "action": "buy", "symbol": "{{ticker}}", "price": "{{close}}", "message": "Long entry — MTF Pyramid Pullback"}')

alertcondition(sell_signal_edge, title="Sell Signal (Short Entry)",
     message='{"secret": "SECRET", "strategy": "HyperTrader Regime MTF v3", "action": "sell", "symbol": "{{ticker}}", "price": "{{close}}", "message": "Short entry — EMA Crossover"}')

alertcondition(close_signal_edge, title="Close Signal",
     message='{"secret": "SECRET", "strategy": "HyperTrader Regime MTF v3", "action": "close", "symbol": "{{ticker}}", "price": "{{close}}", "message": "Position closed — regime change or exit condition"}')

// ─── END ────────────────────────────────────────────────────────────────────────
