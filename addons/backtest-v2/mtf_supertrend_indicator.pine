//@version=5
indicator("MTF Supertrend + ADX + Squeeze", overlay=true)

// ─── INPUTS ───────────────────────────────────────────────────
// 15m Supertrend
st_atr    = input.int(10,    "ST ATR Period",    group="15m Supertrend")
st_mult   = input.float(4.0, "ST Multiplier",    group="15m Supertrend", step=0.1)

// 1H Supertrend
st1h_atr  = input.int(10,    "1H ST ATR Period", group="1H Confirmation")
st1h_mult = input.float(4.0, "1H ST Multiplier", group="1H Confirmation", step=0.1)

// ADX
adx_len   = input.int(14,    "ADX Period",       group="ADX Filter")
adx_min   = input.float(15,  "ADX Minimum",      group="ADX Filter")
adx_lb    = input.int(4,     "ADX Rising Lookback", group="ADX Filter", tooltip="ADX must be higher than this many bars ago")

// Squeeze
bb_len    = input.int(20,    "BB Length",         group="Squeeze Momentum")
bb_mult   = input.float(2.0, "BB Multiplier",    group="Squeeze Momentum", step=0.1)
kc_len    = input.int(20,    "KC Length",         group="Squeeze Momentum")
kc_mult   = input.float(1.5, "KC Multiplier",    group="Squeeze Momentum", step=0.1)

// Webhook secret
webhook_secret = input.string("yYkzLcgih-s4ArCrSvi2oij5rVYGkz7LwJBZ7O9BocU", "Webhook Secret", group="Webhook", tooltip="Must match your bot's webhook secret")

// ─── 15M SUPERTREND ───────────────────────────────────────────
[st_line, st_dir] = ta.supertrend(st_mult, st_atr)

// st_dir: -1 = bullish (price above ST), +1 = bearish (price below ST)
// TradingView convention: supertrend direction is -1 for uptrend, +1 for downtrend
bullish = st_dir == -1
bearish = st_dir == 1

flip_bull = bullish and not bullish[1]
flip_bear = bearish and not bearish[1]

// ─── 1H SUPERTREND CONFIRMATION ──────────────────────────────
// Request 1H Supertrend direction
// Using same-ticker on 60m timeframe, gaps=barmerge.gaps_off for continuous data
[st1h_line, st1h_dir] = request.security(syminfo.tickerid, "60", ta.supertrend(st1h_mult, st1h_atr), barmerge.gaps_off, barmerge.lookahead_off)

htf_bullish = st1h_dir == -1
htf_bearish = st1h_dir == 1

// ─── ADX FILTER ──────────────────────────────────────────────
// ta.adx returns the ADX value
adx_val = ta.adx(adx_len)
adx_ok  = adx_val >= adx_min
adx_rising = adx_val > adx_val[adx_lb]
adx_pass = adx_ok and adx_rising

// ─── SQUEEZE MOMENTUM ────────────────────────────────────────
// Bollinger Bands
bb_basis = ta.sma(close, bb_len)
bb_dev   = bb_mult * ta.stdev(close, bb_len)
upper_bb = bb_basis + bb_dev
lower_bb = bb_basis - bb_dev

// Keltner Channels (LazyBear uses SMA of TR, not RMA)
kc_tr    = ta.tr(true)
kc_atr   = ta.sma(kc_tr, kc_len)
kc_basis = ta.sma(close, kc_len)
upper_kc = kc_basis + kc_mult * kc_atr
lower_kc = kc_basis - kc_mult * kc_atr

// Squeeze ON = BB inside KC
squeeze_on = lower_bb > lower_kc and upper_bb < upper_kc
squeeze_off = not squeeze_on

// ─── COMBINED SIGNALS ─────────────────────────────────────────
buy_signal  = flip_bull and htf_bullish and adx_pass and squeeze_off
sell_signal = flip_bear and htf_bearish and adx_pass and squeeze_off

// ─── PLOTS ────────────────────────────────────────────────────
// Supertrend line
plot(st_line, "Supertrend", color=bullish ? color.green : color.red, linewidth=2)

// Signal labels
plotshape(buy_signal,  "Buy",  shape.labelup,   location.belowbar, color.new(color.green, 0), text="BUY",  textcolor=color.white, size=size.small)
plotshape(sell_signal, "Sell", shape.labeldown,  location.abovebar, color.new(color.red, 0),   text="SELL", textcolor=color.white, size=size.small)

// Background color for 1H trend
bgcolor(htf_bullish ? color.new(color.green, 95) : htf_bearish ? color.new(color.red, 95) : na, title="1H Trend Background")

// Squeeze dots on zero line (like LazyBear)
// Not plotted on overlay chart — use a separate pane if you want these

// ─── INFO TABLE ───────────────────────────────────────────────
var table info = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    table.cell(info, 0, 0, "15m ST",     text_color=color.white, text_size=size.small)
    table.cell(info, 1, 0, bullish ? "BULL" : "BEAR", text_color=bullish ? color.green : color.red, text_size=size.small)
    table.cell(info, 0, 1, "1H ST",      text_color=color.white, text_size=size.small)
    table.cell(info, 1, 1, htf_bullish ? "BULL" : "BEAR", text_color=htf_bullish ? color.green : color.red, text_size=size.small)
    table.cell(info, 0, 2, "ADX(" + str.tostring(adx_len) + ")", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 2, str.tostring(adx_val, "#.#") + (adx_rising ? " ↑" : " ↓"), text_color=adx_pass ? color.green : color.gray, text_size=size.small)
    table.cell(info, 0, 3, "Squeeze",    text_color=color.white, text_size=size.small)
    table.cell(info, 1, 3, squeeze_on ? "ON" : "OFF", text_color=squeeze_on ? color.orange : color.green, text_size=size.small)
    table.cell(info, 0, 4, "Signal",     text_color=color.white, text_size=size.small)
    ready = (htf_bullish or htf_bearish) and adx_pass and squeeze_off
    table.cell(info, 1, 4, ready ? "READY" : "BLOCKED", text_color=ready ? color.green : color.red, text_size=size.small)

// ─── ALERTS ───────────────────────────────────────────────────
buy_msg  = '{"secret": "' + webhook_secret + '", "strategy": "BTC Supertrend MTF", "action": "buy", "symbol": "' + syminfo.ticker + '", "size_pct": 2, "price": "' + str.tostring(close) + '", "message": "MTF Buy Signal — ST flip bull + 1H bull + ADX ' + str.tostring(adx_val, "#.#") + ' rising + squeeze off"}'
sell_msg = '{"secret": "' + webhook_secret + '", "strategy": "BTC Supertrend MTF", "action": "sell", "symbol": "' + syminfo.ticker + '", "size_pct": 2, "price": "' + str.tostring(close) + '", "message": "MTF Sell Signal — ST flip bear + 1H bear + ADX ' + str.tostring(adx_val, "#.#") + ' rising + squeeze off"}'

alertcondition(buy_signal,  "MTF Buy Signal",  buy_msg)
alertcondition(sell_signal, "MTF Sell Signal", sell_msg)
